      "id": "6c9aafdc-96cd-4712-a5e8-b14845183611",
      "name": "GET Tablas Destino",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        -16,
        128
      ]
    },
    {
      "parameters": {
        "jsCode": "// 1. IMPORTANTE: Extraemos las tablas del nodo que SÍ tiene el detalle de las columnas\nconst sourceTables = $('GET Detalles Tablas Origen').all().map(i => i.json);\n\nconst destData = $input.item.json;\nconst destTables = destData.list || destData;\n\nlet columnsToCreate = [];\n\nfor (const sTable of sourceTables) {\n   const dTable = destTables.find(t => t.title === sTable.title || t.table_name === sTable.table_name);\n   if (!dTable) continue;\n   \n   for (const col of sTable.columns || []) {\n      // Excluir columnas del sistema y relaciones para esta primer fase\n      if (col.system || col.uidt === 'ID' || ['CreatedTime', 'LastModifiedTime', 'LinkToAnotherRecord', 'Links', 'Formula', 'Lookup', 'Rollup', 'CreatedBy', 'LastModifiedBy'].includes(col.uidt)) \n {\n         continue;\n      }\n      // Evitar crear si ya existe (ej. la base de destino u otra columna auto-generada)\n      if (dTable.columns && dTable.columns.find(dc => dc.title === col.title)) {\n         continue;\n      }\n      \n      columnsToCreate.push({\n         dest_table_id: dTable.id,\n         column_name: col.column_name,\n         title: col.title,\n         uidt: col.uidt,\n         dt: col.dt,\n         dtxp: col.dtxp,\n         dtxs: col.dtxs,\n         cdf: ['MultiSelect', 'SingleSelect'].includes(col.uidt) ? null : col.cdf,\n         un: col.un,\n         rqd: col.rqd\n      });\n   }\n}\n\n// 2. TRUCO DE N8N: Si está vacío, retornamos un elemento ficticio { _empty: true }. \n// Así n8n no frena la ejecución, el request fallará por una vez silenciosamente y pasará a crear las relaciones.\nif (columnsToCreate.length === 0) {\n    return [{ json: { _empty: true } }];\n}\n\nreturn columnsToCreate.map(c => ({ json: c }));\n"
      },
