      "id": "49fe329a-b834-4320-866f-0ed495cf92de",
      "name": "POST Crear Columna",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        544,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const sourceTables = $('GET Detalles Tablas Origen').all().map(i => i.json);\nconst destData = $('GET Tablas Destino').first().json;\nconst destTables = destData.list || destData;\n\nconst tableMap = {};\nfor (const sTable of sourceTables) {\n   const dTable = destTables.find(t => t.title === sTable.title || t.table_name === sTable.table_name);\n   if (dTable) tableMap[sTable.id] = dTable.id;\n}\n\nlet relationsToCreate = [];\n\nfor (const sTable of sourceTables) {\n   const dTableId = tableMap[sTable.id];\n   if (!dTableId) continue;\n\n   for (const col of sTable.columns || []) {\n      if (['LinkToAnotherRecord', 'Links'].includes(col.uidt) && col.colOptions) {\n         const relatedSourceTableId = col.colOptions.fk_related_model_id;\n         const relatedDestTableId = tableMap[relatedSourceTableId];\n         \n                  if (relatedDestTableId) {\n            const originalType = col.colOptions.type;\n            \n            // Asignamos el Padre y el Hijo\n            let parentId = dTableId;\n            let childId = relatedDestTableId;\n            \n            if (originalType === \"bt\") {\n               parentId = relatedDestTableId;\n               childId = dTableId;\n            }\n\n            // Saltamos relaciones duplicadas para evitar crash\n            if (originalType === \"hm\") continue; \n            if (originalType === \"mm\" && sTable.id > relatedSourceTableId) continue;\n\n            relationsToCreate.push({\n               dest_table_id: dTableId,\n               title: col.title,\n               column_name: col.column_name, // Lo volvemos a enviar por si acaso\n               uidt: 'Links',\n               type: originalType, // <--- AQUÍ LE MANDAMOS EL CÓDIGO DIRECTO: 'mm', 'bt', etc.\n               parentId: parentId,\n               childId: childId\n            });\n         }\n\n      }\n   }\n}\n\nif (relationsToCreate.length === 0) return [{ json: { _empty: true } }];\nreturn relationsToCreate.map(r => ({ json: r }));\n"
      },
