    {
      "parameters": {
        "jsCode": "// Tomamos la fecha de inicio desde el input\nconst fechaInicioTexto = $('When Executed by Another Workflow').first().json.Fecha; // Ej: \"2025-12-01T17:30:00\"\nconst duracionMinutos = Number($('When Executed by Another Workflow').first().json.Duracion); // Ej: \"30\" -> 30\n\n// Convertir a Date\nconst fechaInicio = new Date(fechaInicioTexto);\n\n// Crear fecha fin sumando los minutos\nconst fechaFin = new Date(fechaInicio.getTime() + duracionMinutos * 60000);\n\n// Formatear ambas a 'YYYY-MM-DDTHH:mm:ss'\nfunction formatear(fecha) {\n  return fecha.toISOString().substring(0, 19);\n}\n\nreturn [\n  {\n    json: {\n      FechaInicio: formatear(fechaInicio),\n      FechaFin: formatear(fechaFin),\n    }\n  }\n];\n"
      },
      "type": "n8n-nodes-base.code",
