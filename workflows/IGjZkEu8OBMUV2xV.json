    {
      "parameters": {
        "jsCode": "// Resultados del nodo anterior\nconst successArray = $json.success || [];\n\n// Eventos obtenidos del nodo \"Get many events\"\nconst eventos = $('Get many events').all();\n\n// Función para formatear fecha\nfunction formatear(fechaISO) {\n  if (!fechaISO) return \"Sin fecha\";\n  return fechaISO.substring(0, 16).replace(\"T\", \" \");\n}\n\n// Contar resultados\nconst trueCount = successArray.filter(v => v === true).length;\nconst hasFalse = successArray.includes(false);\n\nlet message = \"\";\n\n// Armamos lista de eliminados (solo los true)\nconst eliminados = successArray\n  .map((ok, index) => {\n    if (!ok) return null;\n\n    const evento = eventos[index]?.json;\n\n    const inicio = formatear(evento?.start?.dateTime);\n    const fin = formatear(evento?.end?.dateTime);\n\n    return `• inicio: ${inicio}\n  fin: ${fin}`;\n  })\n  .filter(Boolean)\n  .join(\"\\n\\n\");\n\n// Mensaje final\nif (successArray.length === 0) {\n  message = \"No se recibieron resultados para procesar.\";\n} else if (!hasFalse) {\n  message = `Se eliminaron ${trueCount} horarios bloqueados correctamente:\n\n${eliminados}`;\n} else {\n  const falseCount = successArray.length - trueCount;\n\n  message = `Se eliminaron ${trueCount} horarios bloqueados correctamente, pero ${falseCount} no pudieron eliminarse.\n\nHorarios eliminados:\n${eliminados}`;\n}\n\nreturn [\n  {\n    json: {\n      mensaje: message\n    }\n  }\n];"
      },
