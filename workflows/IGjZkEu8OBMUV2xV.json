    {
      "parameters": {
        "jsCode": "const items = $('When Executed by Another Workflow').all();\nreturn items.map(item => {\n\n  const fechaInicio = item.json.Inicio;\n  const fechaFin = item.json.Fin;\n\n  if (!fechaInicio || !fechaFin) {\n    throw new Error(\"Fecha_inicio o Fecha_fin no fueron enviadas.\");\n  }\n\n  const startObj = new Date(fechaInicio);\n  const endObj = new Date(fechaFin);\n\n  // Validar que sean fechas reales\n  if (isNaN(startObj.getTime()) || isNaN(endObj.getTime())) {\n    throw new Error(\"Una de las fechas no es válida.\");\n  }\n\n  // Validar que fin sea mayor que inicio\n  if (endObj <= startObj) {\n    throw new Error(\"La Fecha_fin debe ser mayor que la Fecha_inicio.\");\n  }\n\n  return {\n    json: {\n      startTime: fechaInicio,\n      endTime: fechaFin\n    }\n  };\n});"
      },
