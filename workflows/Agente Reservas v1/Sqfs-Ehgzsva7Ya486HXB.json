    {
      "parameters": {
        "jsCode": "const intervalos = $json.intervalosDisponibles;\nconst fecha = $('Code').item.json.fecha_sola;\n\nfunction esManana(hora) {\n  const h = parseInt(hora.split(\":\")[0], 10);\n  return h < 13;\n}\n\nfunction esTarde(hora) {\n  const h = parseInt(hora.split(\":\")[0], 10);\n  return h >= 13;\n}\n\nlet manana = [];\nlet tarde = [];\n\nfor (const i of intervalos) {\n  if (esManana(i.desde)) {\n    manana.push(i);\n  } else {\n    tarde.push(i);\n  }\n}\n\nlet texto = `No hay disponibilidad para el horario solicitado. Estos son los horarios disponibles para el ${fecha}:\\n`;\n\nif (manana.length) {\n  texto += `\\nPor la mañana:\\n`;\n  manana.forEach(i => {\n    texto += `• Desde ${i.desde} hasta ${i.hasta}\\n`;\n  });\n}\n\nif (tarde.length) {\n  texto += `\\nPor la tarde:\\n`;\n  tarde.forEach(i => {\n    texto += `• Desde ${i.desde} hasta ${i.hasta}\\n`;\n  });\n}\n\nreturn [{ texto }];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2048,
