    {
      "parameters": {
        "jsCode": "// Fecha ORIGINAL (no tocar)\nconst fechaOriginal = new Date($('When Executed by Another Workflow').first().json.Fecha);\n\n// Duración\nconst duracionMinutos = Number($input.first().json.Tiempo_estimado_min);\n\n// ---- FORMATO LEGIBLE usando la fecha original ----\nconst dia = String(fechaOriginal.getDate()).padStart(2, \"0\");\nconst mes = String(fechaOriginal.getMonth() + 1).padStart(2, \"0\");\nconst anio = fechaOriginal.getFullYear();\n\nconst horas = String(fechaOriginal.getHours()).padStart(2, \"0\");\nconst minutos = String(fechaOriginal.getMinutes()).padStart(2, \"0\");\n\nconst fecha_formateada = `${dia}/${mes}/${anio} a las ${horas}:${minutos} hs`;\n\nconst fecha_sola = `${dia}/${mes}/${anio}`;\n\n// ---- Calcular FechaFin ----\nconst fechaFinObj = new Date(fechaOriginal);\nfechaFinObj.setMinutes(fechaFinObj.getMinutes() + duracionMinutos);\n\nconst fechaFin = fechaFinObj.toISOString().substring(0, 19);\n\nreturn [\n  {\n    json: {\n      FechaInicio: $('When Executed by Another Workflow').first().json.Fecha,\n      DuracionMinutos: duracionMinutos,\n      FechaFin: fechaFin,\n      fecha_formateada: fecha_formateada,\n      fecha_sola: fecha_sola\n    }\n  }\n];\n\n"
      },
