    {
      "parameters": {
        "jsCode": "function convertirAHorasMinutos(valor) {\n\n  const debug = {};\n\n  if (!valor) {\n    debug.error = \"valor vacío o null\";\n    return { minutos: NaN, debug };\n  }\n\n  const str = String(valor).trim();\n  const partes = str.split(\":\");\n\n  debug.original = valor;\n  debug.string = str;\n  debug.partes = partes;\n\n  if (partes.length < 2) {\n    debug.error = \"no tiene formato HH:MM\";\n    return { minutos: NaN, debug };\n  }\n\n  const hh = parseInt(partes[0], 10);\n  const mm = parseInt(partes[1], 10);\n\n  debug.hh = hh;\n  debug.mm = mm;\n\n  if (isNaN(hh) || isNaN(mm)) {\n    debug.error = \"hora o minutos no numéricos\";\n    return { minutos: NaN, debug };\n  }\n\n  return { minutos: hh * 60 + mm, debug };\n}\n\n\n/* 📦 DATOS DE OTROS NODOS */\nconst horariosDB = $('Horarios Formateados').first().json;\nconst datosFecha = $('Obtener hora y dia de la semana').first().json;\n\nconst horaInput = datosFecha.hora;\nconst diaSemana = datosFecha.diaSemana;\n\nconst duracionServicioRaw =\n  $('When Executed by Another Workflow').first().json.Duracion;\n\nconst duracionServicio = Number(String(duracionServicioRaw).trim());\n\n\n/* 🔧 HORARIOS SEGÚN DÍA */\nconst HORARIOS = {\n  inicioAtencion: horariosDB[`HoEn-${diaSemana}`],\n  finAtencion: horariosDB[`HoSal-${diaSemana}`],\n  inicioAlmuerzo: horariosDB[`HoInRec-${diaSemana}`],\n  finAlmuerzo: horariosDB[`HoFiRec-${diaSemana}`],\n};\n\n\n/* ⏱ CONVERSIONES */\nconst inicio = convertirAHorasMinutos(horaInput);\nconst inicioAtencion = convertirAHorasMinutos(HORARIOS.inicioAtencion);\nconst finAtencion = convertirAHorasMinutos(HORARIOS.finAtencion);\nconst inicioAlmuerzo = convertirAHorasMinutos(HORARIOS.inicioAlmuerzo);\nconst finAlmuerzo = convertirAHorasMinutos(HORARIOS.finAlmuerzo);\n\n\nfor (const item of $input.all()) {\n\n  let valida = true;\n  let justificacion = \"\";\n\n  if (!Number.isFinite(inicio.minutos)) {\n    valida = false;\n    justificacion = \"Hora inválida\";\n  }\n  else if (!Number.isFinite(duracionServicio) || duracionServicio <= 0) {\n    valida = false;\n    justificacion = \"Duración inválida\";\n  }\n  else {\n\n    const fin = inicio.minutos + duracionServicio;\n\n    if (inicio.minutos < inicioAtencion.minutos) {\n      valida = false;\n      justificacion = `Comienza antes del horario de atención (${HORARIOS.inicioAtencion})`;\n    }\n    else if (inicio.minutos >= finAtencion.minutos) {\n      valida = false;\n      justificacion = `Comienza después del horario de atención (${HORARIOS.finAtencion})`;\n    }\n    else if (fin > finAtencion.minutos) {\n      valida = false;\n      justificacion = `El servicio termina después del cierre (${HORARIOS.finAtencion})`;\n    }\n    else if (inicio.minutos < finAlmuerzo.minutos && fin > inicioAlmuerzo.minutos) {\n      valida = false;\n      justificacion = `Interfiere con el almuerzo (${HORARIOS.inicioAlmuerzo} - ${HORARIOS.finAlmuerzo})`;\n    }\n  }\n\n  item.json.valida = valida;\n  item.json.justificacion = valida ? \"\" : justificacion;\n\n\n}\n\nreturn $input.all();"
      },
