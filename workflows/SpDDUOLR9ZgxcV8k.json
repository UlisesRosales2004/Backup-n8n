    {
      "parameters": {
        "jsCode": "// Obtener valores\nconst diasDisponibles = $('When Executed by Another Workflow').first().json.DiaDisponible;\nconst fechaCompleta = $('When Executed by Another Workflow').first().json.Fecha;\n\n// Extraer solo la fecha\nconst fechaSoloDia = fechaCompleta.split('T')[0];\n\n// Convertir a array y limpiar valores inválidos\nconst arrayDias = (diasDisponibles || '')\n  .split(',')\n  .map(d => d.trim())\n  .filter(d => d && d !== 'null');\n\n// Comparar\nconst esIgual = arrayDias.includes(fechaSoloDia);\n\n// Resultado\nreturn [\n  {\n    json: {\n      resultado: esIgual\n    }\n  }\n];"
      },
