    {
      "parameters": {
        "jsCode": "// Fecha recibida\nconst fechaStr = $('When Executed by Another Workflow').first().json.Fecha;\n\n/*\nParse seguro SIN Date(string)\n*/\nconst [datePart, timePart] = fechaStr.split('T');\nconst [year, month, day] = datePart.split('-').map(Number);\nconst [hour, minute, second] = timePart.split(':').map(Number);\n\n// Convertimos la fecha a Luxon (hora local real)\nconst ahoraLuxon = $now.setZone('America/Argentina/Buenos_Aires');\n\nconst fechaLuxon = ahoraLuxon.set({\n  year,\n  month,\n  day,\n  hour,\n  minute,\n  second: second || 0\n});\n\n// ----------------------\n// Margen configurable\n// ----------------------\nconst margenMin = 30; // ← CAMBIAR SOLO ESTO\n\nconst ahoraMasMargen = ahoraLuxon.plus({ minutes: margenMin });\n\n// ----------------------\n// ¿Es hoy?\n// ----------------------\nconst esHoy = fechaLuxon.hasSame(ahoraLuxon, 'day');\n\nlet valida;\n\nif (!esHoy) {\n  valida = true;\n} else {\n  valida = fechaLuxon > ahoraMasMargen;\n}\n\nreturn [\n  {\n    json: {\n      valida,\n      debug: {\n        ahoraArgentina: ahoraLuxon.toFormat('HH:mm'),\n        fechaArgentina: fechaLuxon.toFormat('HH:mm'),\n        ahoraMasMargen: ahoraMasMargen.toFormat('HH:mm'),\n        margenMin,\n        esHoy\n      }\n    }\n  }\n];"
      },
