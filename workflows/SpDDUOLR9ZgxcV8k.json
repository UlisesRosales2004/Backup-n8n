    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "6d12b307-21cb-482a-a7a2-9c61a5399282",
              "name": "Justificacion",
              "value": "={{\n(() => {\n\n  const data = $('When Executed by Another Workflow').item.json;\n\n  const disponibilidadRaw = data.Disponibilidad || \"\";\n  const fechasRaw = data.DiaDisponible || \"\";\n\n  const disponibles = disponibilidadRaw\n    .split(',')\n    .map(d => d.trim())\n    .filter(Boolean);\n\n  const tieneDiaSeleccionado = disponibles.includes(\"Día Seleccionado\");\n\n  const diasSemana = disponibles.filter(d => d !== \"Día Seleccionado\");\n\n  let fechas = [];\n\n  if (tieneDiaSeleccionado && fechasRaw) {\n    fechas = fechasRaw\n      .split(',')\n      .map(f => {\n        const fecha = f.trim();\n        if (!fecha) return null;\n\n        const [y,m,d] = fecha.split(\"-\");\n        return `el ${d}/${m}/${y}`;\n      })\n      .filter(Boolean);\n  }\n\n  const todos = [...diasSemana, ...fechas];\n\n  if (todos.length === 0) {\n    return \"Inválido. El servicio seleccionado no tiene días disponibles para agendar.\";\n  }\n\n  let lista;\n\n  if (todos.length === 1) {\n    lista = todos[0];\n  } else if (todos.length === 2) {\n    lista = `${todos[0]} y ${todos[1]}`;\n  } else {\n    lista = `${todos.slice(0,-1).join(', ')} y ${todos[todos.length-1]}`;\n  }\n\n  return `Inválido. El servicio seleccionado solo se puede agendar los siguientes días: ${lista}.`;\n\n})()\n}}",
              "type": "string"
            },
            {
              "id": "c4a09681-b1c2-4ec6-b0d3-ae931c9d7f80",
              "name": "Valida",
              "value": false,
              "type": "boolean"
            }
          ]
        },
